{
  "id": "santa_tracker",
  "name": "Santa Tracker",
  "version": "1.0.0",
  "description": "Track Santa's journey around the world as midnight of December 25th hits famous locations in each timezone",
  "author": "FiestaBoard Team",
  "icon": "gift",
  "category": "entertainment",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--santa-tracker",
  "documentation": "README.md",
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enabled",
        "default": true
      },
      "year": {
        "type": "integer",
        "title": "Christmas Year",
        "description": "The year to track Santa for. Defaults to the current year.",
        "minimum": 2024,
        "maximum": 2100
      }
    }
  },
  "variables": {
    "simple": [
      "status",
      "santa_location",
      "last_visited",
      "next_stop",
      "visited_count",
      "total_locations",
      "progress_percent",
      "year"
    ],
    "arrays": {
      "locations": {
        "label_field": "name",
        "item_fields": [
          "name",
          "state"
        ]
      }
    }
  },
  "max_lengths": {
    "status": 40,
    "santa_location": 35,
    "last_visited": 35,
    "next_stop": 35,
    "visited_count": 2,
    "total_locations": 2,
    "progress_percent": 3,
    "year": 4,
    "locations.*.name": 35,
    "locations.*.state": 8
  },
  "fiestaboard_version": ">=2.10.0"
}
