{
  "id": "santa_tracker",
  "name": "Santa Tracker",
  "version": "1.0.0",
  "description": "Track Santa's journey around the world as midnight of December 25th hits famous locations in each timezone",
  "author": "FiestaBoard Team",
  "icon": "gift",
  "category": "entertainment",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--santa-tracker",
  "documentation": "README.md",
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enabled",
        "default": true
      },
      "year": {
        "type": "integer",
        "title": "Christmas Year",
        "description": "The year to track Santa for. Defaults to the current year.",
        "minimum": 2024,
        "maximum": 2100
      }
    }
  },
  "variables": {
    "groups": {
      "status": {
        "label": "Status"
      },
      "journey": {
        "label": "Journey Progress"
      }
    },
    "simple": {
      "status": {
        "description": "Current Santa tracking status message",
        "type": "string",
        "max_length": 40,
        "group": "status",
        "example": "Santa is on his way!"
      },
      "santa_location": {
        "description": "City/location where Santa currently is",
        "type": "string",
        "max_length": 35,
        "group": "journey",
        "example": "Tokyo, Japan"
      },
      "last_visited": {
        "description": "Last city Santa visited",
        "type": "string",
        "max_length": 35,
        "group": "journey",
        "example": "Sydney, Australia"
      },
      "next_stop": {
        "description": "Next city on Santa's route",
        "type": "string",
        "max_length": 35,
        "group": "journey",
        "example": "Beijing, China"
      },
      "visited_count": {
        "description": "Number of locations visited so far",
        "type": "number",
        "max_length": 2,
        "group": "journey",
        "example": "12"
      },
      "total_locations": {
        "description": "Total number of locations on the route",
        "type": "number",
        "max_length": 2,
        "group": "journey",
        "example": "24"
      },
      "progress_percent": {
        "description": "Percentage of journey completed",
        "type": "number",
        "max_length": 3,
        "group": "journey",
        "example": "50"
      },
      "year": {
        "description": "The Christmas year being tracked",
        "type": "number",
        "max_length": 4,
        "group": "status",
        "example": "2025"
      }
    },
    "arrays": {
      "locations": {
        "label_field": "name",
        "item_fields": [
          "name",
          "state"
        ]
      }
    }
  },
  "max_lengths": {
    "locations.*.name": 35,
    "locations.*.state": 8
  },
  "fiestaboard_version": ">=2.10.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Santa Tracker displayed on a Vestaboard",
      "caption": "Track Santa's journey around the world as midnight of December 25th hits famous locations in each timezone",
      "primary": true
    }
  ]
}
